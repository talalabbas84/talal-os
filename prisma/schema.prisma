generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inboxEntries      InboxEntry[]
  projects          Project[]
  tasks             Task[]
  dailyLogs         DailyLog[]
  habits            Habit[]
  memoryEntries     MemoryEntry[]
  userState         UserState?
  dailyPlans        DailyPlan[]
  followUps         FollowUp[]
  growthItems       GrowthItem[]
  followUpQuestions FollowUpQuestion[]
  thoughts          Thought[]
  thoughtUnits      ThoughtUnit[]
  expressionRewrites ExpressionRewrite[]
  expressionTrends  ExpressionTrend[]
  conversations      Conversation[]
  conversationAnswers ConversationAnswer[]
  discoveryXp        DiscoveryXp[]
  companionStreaks   CompanionStreak[]
  learningItems     LearningItem[]
  reviewSessions    ReviewSession[]
  activityLogs      ActivityLog[]
  eventPlaceholders EventPlaceholder[]
  dayPulses         DayPulse[]
  people            Person[]
  personInteractions PersonInteraction[]
  personMemories    PersonMemory[]
  personInsights    PersonInsight[]
  personalProfile   PersonalProfile?
  personalInsights  PersonalInsight[]
  personalPatterns  PersonalPattern[]
  reflectionQuestions ReflectionQuestion[]
  personalGrowthAreas PersonalGrowthArea[]
  timelineEvents    TimelineEvent[]
  dailyReflections  DailyReflection[]
  captureRecords    CaptureRecord[]
  knowledgeGraphEdges KnowledgeGraphEdge[]
  captureDrafts     CaptureDraft[]
  pushSubscriptions PushSubscription[]
}

model UserState {
  id             String    @id @default(cuid())
  currentMood    String?
  energyLevel    Level?
  focusLevel     Level?
  recoveryMode   Boolean   @default(false)
  currentMission String?
  weekFocus      String?
  lastReflection DateTime?
  lastPlanning   DateTime?
  updatedAt      DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InboxEntry {
  id          String         @id @default(cuid())
  title       String
  description String?
  category    InboxCategory?
  status      InboxStatus    @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  priority    Priority      @default(MEDIUM)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Time awareness
  dueTime     String?   // "morning" | "afternoon" | "evening" | "night"
  timeContext String?   // "tonight" | "after_work" | "this_weekend" | "before_dance" …

  // Reminder intent (notifications built in v0.5+)
  needsReminder   Boolean   @default(false)
  reminderAt      DateTime?
  sourceCaptureId String?

  // Priority matrix
  importance     Level @default(MEDIUM)
  urgency        Level @default(MEDIUM)
  energyRequired Level @default(MEDIUM)
  priorityScore  Int?  // urgency + importance - energy penalty (0–6)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([projectId])
  @@index([priorityScore])
  @@index([urgency])
}

model DailyLog {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  feeling      String?
  accomplished String?
  distracted   String?
  improve      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model DailyPlan {
  id                 String    @id @default(cuid())
  date               DateTime  @db.Date
  summary            String
  todayMission       String
  topThreeTaskIds    String[]  @default([])
  recommendedHabits  String[]  @default([])
  peopleToFollowUp   String[]  @default([])
  ideasToIgnore      String[]  @default([])
  focusMode          String?
  recoveryMode       Boolean   @default(false)
  generatedAt        DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model FollowUp {
  id          String         @id @default(cuid())
  title       String
  type        FollowUpType
  dueDate     DateTime?
  status      FollowUpStatus @default(OPEN)
  reason      String?
  createdFrom String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([type])
}

model GrowthItem {
  id              String          @id @default(cuid())
  category        GrowthCategory
  title           String
  description     String?
  currentStage    GrowthStage     @default(LEARNED)
  lastReviewed    DateTime?
  nextReview      DateTime?
  confidence      Level           @default(MEDIUM)
  sourceCaptureId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([currentStage])
  @@index([nextReview])
}

model FollowUpQuestion {
  id                String                 @id @default(cuid())
  category          GrowthCategory
  question          String
  reason            String?
  priority          Level                  @default(MEDIUM)
  status            FollowUpQuestionStatus @default(OPEN)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime               @default(now())
  answeredAt        DateTime?
  updatedAt         DateTime               @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([relatedEntityType, relatedEntityId])
}

model Thought {
  id                String           @id @default(cuid())
  rawText           String
  cleanedText       String
  summary           String
  category          ThoughtCategory
  emotionalTone     String?
  importance        MemoryImportance @default(MEDIUM)
  relatedPeopleIds  String[]         @default([])
  relatedProjectId  String?
  source            ThoughtSource    @default(CAPTURE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([importance])
  @@index([createdAt])
}

model ThoughtUnit {
  id              String          @id @default(cuid())
  rawText         String
  cleanedText     String
  type            ThoughtUnitType
  confidence      Level           @default(MEDIUM)
  sourceCaptureId String?
  routedTo        String?
  createdAt       DateTime        @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model ExpressionRewrite {
  id                    String   @id @default(cuid())
  rawText               String
  articulatedText       String
  improvedText          String
  explanation           String?
  vocabularySuggestions Json?
  ambiguityNotes        Json?
  clarificationQuestion String?
  createdAt             DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ExpressionTrend {
  id                String   @id @default(cuid())
  clarity           String
  specificity       String
  vocabularyVariety String
  structure         String
  notes             String?
  createdAt         DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Conversation {
  id            String             @id @default(cuid())
  mode          ConversationMode
  slot          ConversationSlot
  prompt        String
  contextNote   String?
  status        ConversationStatus @default(PENDING)
  depth         Int                @default(1)
  followUpCount Int                @default(0)
  source        Json?
  scheduledFor  DateTime?
  answeredAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  userId  String
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers ConversationAnswer[]

  @@index([userId])
  @@index([status])
  @@index([slot])
  @@index([mode])
  @@index([createdAt])
}

model ConversationAnswer {
  id             String              @id @default(cuid())
  answer         String
  feedback       String?
  insight        String?
  xpCategory     DiscoveryXpCategory
  xpAmount       Int                 @default(0)
  meaningful     Boolean             @default(false)
  createdAt      DateTime            @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([xpCategory])
  @@index([createdAt])
}

model DiscoveryXp {
  id        String              @id @default(cuid())
  category  DiscoveryXpCategory
  xp        Int                 @default(0)
  updatedAt DateTime            @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

model CompanionStreak {
  id               String              @id @default(cuid())
  type             CompanionStreakType
  currentCount     Int                 @default(0)
  bestCount        Int                 @default(0)
  lastActivityDate DateTime?           @db.Date
  updatedAt        DateTime            @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model LearningItem {
  id              String                @id @default(cuid())
  title           String
  content         String
  category        LearningCategory
  source          LearningSource        @default(CAPTURE)
  difficulty      Level                 @default(MEDIUM)
  masteryLevel    LearningMasteryLevel  @default(NEW)
  lastReviewedAt  DateTime?
  nextReviewAt    DateTime?
  reviewCount     Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers ReviewAnswer[]

  @@index([userId])
  @@index([category])
  @@index([masteryLevel])
  @@index([nextReviewAt])
}

model ReviewSession {
  id        String            @id @default(cuid())
  date      DateTime          @db.Date
  category  LearningCategory?
  score     Int?
  createdAt DateTime          @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers ReviewAnswer[]

  @@index([userId])
  @@index([date])
  @@index([category])
}

model ReviewAnswer {
  id             String           @id @default(cuid())
  prompt         String
  answer         String
  selfRating     ReviewSelfRating
  createdAt      DateTime         @default(now())

  reviewSessionId String
  reviewSession   ReviewSession @relation(fields: [reviewSessionId], references: [id], onDelete: Cascade)

  learningItemId String
  learningItem   LearningItem  @relation(fields: [learningItemId], references: [id], onDelete: Cascade)

  @@index([reviewSessionId])
  @@index([learningItemId])
}

model ActivityLog {
  id              String           @id @default(cuid())
  activity        String
  category        ActivityCategory
  startedAt       DateTime?
  endedAt         DateTime?
  energyLevel     Level?
  mood            String?
  notes           String?
  sourceCaptureId String?
  createdAt       DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

model EventPlaceholder {
  id              String   @id @default(cuid())
  title           String
  description     String?
  date            DateTime @db.Date
  time            String?
  timeContext     String?
  location        String?
  sourceCaptureId String?
  needsReminder   Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedPersonId String?
  relatedPerson   Person?  @relation(fields: [relatedPersonId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([relatedPersonId])
  @@index([createdAt])
}

model DayPulse {
  id           String         @id @default(cuid())
  scheduledFor DateTime
  sentAt       DateTime?
  answeredAt   DateTime?
  status       DayPulseStatus @default(PENDING)
  prompt       String
  createdAt    DateTime       @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledFor])
  @@index([status])
}

model Habit {
  id          String    @id @default(cuid())
  name        String
  description String?
  frequency   Frequency @default(DAILY)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]

  @@index([userId])
  @@index([isActive])
}

model HabitCompletion {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model MemoryEntry {
  id         String           @id @default(cuid())
  title      String
  content    String
  type       MemoryType
  importance MemoryImportance @default(MEDIUM)
  source     MemorySource     @default(MANUAL)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([importance])
}

model Person {
  id                String    @id @default(cuid())
  name              String
  aliases           String[]  @default([])
  nickname          String?
  relationshipType  String?
  firstMetDate      String?
  firstMetLocation  String?
  birthday          String?
  occupation        String?
  hometown          String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions PersonInteraction[]
  memories     PersonMemory[]
  insights     PersonInsight[]
  events       EventPlaceholder[]

  @@index([userId])
  @@index([name])
}

model PersonInsight {
  id         String        @id @default(cuid())
  type       InsightType
  title      String
  content    String
  confidence Level
  evidence   String[]      @default([])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([personId])
  @@index([type])
}

model PersonInteraction {
  id             String   @id @default(cuid())
  personNameSnapshot String
  date           String
  location       String?
  summary        String
  topics         String[] @default([])
  context        String?
  sentiment      String?
  followUpNeeded Boolean  @default(false)
  followUpDate   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([personId])
  @@index([date])
}

model PersonMemory {
  id         String              @id @default(cuid())
  title      String
  content    String
  importance MemoryImportance    @default(MEDIUM)
  type       PersonMemoryType
  source     PersonMemorySource  @default(MANUAL)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([personId])
  @@index([type])
}

model PersonalProfile {
  id                 String   @id @default(cuid())
  mission            String?
  currentIdentity    String?
  futureIdentity     String?
  coreValues         Json?
  strengths          Json?
  growthAreas        Json?
  learningStyle      Json?
  communicationStyle Json?
  decisionStyle      Json?
  motivationProfile  Json?
  updatedAt          DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalInsight {
  id          String                  @id @default(cuid())
  category    PersonalInsightCategory
  title       String
  description String
  confidence  Level                   @default(MEDIUM)
  evidence    Json
  importance  MemoryImportance        @default(MEDIUM)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([importance])
  @@index([createdAt])
}

model PersonalPattern {
  id          String                  @id @default(cuid())
  category    PersonalInsightCategory
  title       String
  description String
  evidence    Json
  confidence  Level                   @default(MEDIUM)
  lastSeen    DateTime
  occurrences Int                     @default(1)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
  @@index([userId])
  @@index([category])
  @@index([lastSeen])
}

model ReflectionQuestion {
  id             String                   @id @default(cuid())
  question       String
  reason         String?
  priority       Level                    @default(MEDIUM)
  relatedInsight String?
  relatedCapture String?
  status         ReflectionQuestionStatus @default(OPEN)
  createdAt      DateTime                 @default(now())
  answeredAt     DateTime?
  updatedAt      DateTime                 @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model PersonalGrowthArea {
  id                 String         @id @default(cuid())
  dimension          GrowthDimension
  currentConfidence  String?
  momentum           GrowthMomentum @default(STABLE)
  recentWins         Json?
  currentChallenge   String?
  nextRecommendation String?
  updatedAt          DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dimension])
  @@index([userId])
  @@index([dimension])
  @@index([momentum])
}

model TimelineEvent {
  id          String                  @id @default(cuid())
  title       String
  description String?
  category    PersonalInsightCategory
  occurredAt  DateTime?
  importance  MemoryImportance        @default(MEDIUM)
  evidence    Json?
  createdAt   DateTime                @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([importance])
  @@index([occurredAt])
  @@index([createdAt])
}

model DailyReflection {
  id                     String   @id @default(cuid())
  date                   DateTime @db.Date
  whatHappened           String?
  learned                String?
  improved               String?
  struggled              String?
  tomorrowRecommendation String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model CaptureDraft {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model CaptureRecord {
  id          String   @id @default(cuid())
  rawText     String
  cleanedText String
  summary     String?
  intent      String?
  source      String   @default("CAPTURE")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([intent])
  @@index([createdAt])
}

model KnowledgeGraphEdge {
  id         String                 @id @default(cuid())
  sourceType String
  sourceId   String
  relation   KnowledgeGraphRelation
  targetType String
  targetId   String
  confidence Level                  @default(MEDIUM)
  evidence   String?
  metadata   Json?
  createdBy  String                 @default("SYSTEM")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId, relation, targetType, targetId])
  @@index([userId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([relation])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PersonMemoryType {
  BIRTHDAY
  PREFERENCE
  STORY
  BOUNDARY
  COMMUNICATION_STYLE
  IMPORTANT_EVENT
  FOLLOW_UP
  GENERAL
}

enum PersonMemorySource {
  CAPTURE
  MANUAL
  INTERACTION
}

enum KnowledgeGraphRelation {
  CREATED_FROM
  RELATED_TO
  MENTIONS
  REFERENCES_PERSON
  BELONGS_TO_PROJECT
  INSPIRED_BY
  GENERATED
  SCHEDULED_WITH
  FOLLOW_UP_FOR
  LEARNED_FOR
  REINFORCES
  CONTRADICTS
  EVOLVES_FROM
  DUPLICATE_OF
}

enum InsightType {
  COMMUNICATION_STYLE
  SOCIAL_STYLE
  POSSIBLE_VALUES
  ENERGY_PATTERN
  TRUST_PATTERN
  COMPATIBILITY_NOTE
  HOW_TO_APPROACH
  GENERAL
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum InboxCategory {
  IDEA
  TASK
  PROJECT
  GOAL
  JOURNAL
  LEARNING
  FINANCE
  HEALTH
  DANCE
  BUSINESS
  PERSONAL
}

enum InboxStatus {
  PENDING
  PROCESSED
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  BACKLOG
  PAUSED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Frequency {
  DAILY
  WEEKLY
}

enum Level {
  LOW
  MEDIUM
  HIGH
}

enum FollowUpType {
  TASK
  PERSON
  HEALTH
  BUSINESS
  PERSONAL
}

enum FollowUpStatus {
  OPEN
  DONE
  SKIPPED
