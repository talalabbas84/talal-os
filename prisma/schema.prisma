generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inboxEntries  InboxEntry[]
  projects      Project[]
  tasks         Task[]
  dailyLogs     DailyLog[]
  habits        Habit[]
  memoryEntries MemoryEntry[]
  userState     UserState?
}

model UserState {
  id             String    @id @default(cuid())
  currentMood    String?
  energyLevel    Level?
  focusLevel     Level?
  recoveryMode   Boolean   @default(false)
  currentMission String?
  weekFocus      String?
  lastReflection DateTime?
  lastPlanning   DateTime?
  updatedAt      DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InboxEntry {
  id          String         @id @default(cuid())
  title       String
  description String?
  category    InboxCategory?
  status      InboxStatus    @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  priority    Priority      @default(MEDIUM)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Time awareness
  dueTime     String?   // "morning" | "afternoon" | "evening" | "night"
  timeContext String?   // "tonight" | "after_work" | "this_weekend" | "before_dance" …

  // Reminder intent (notifications built in v0.5+)
  needsReminder   Boolean   @default(false)
  reminderAt      DateTime?
  sourceCaptureId String?

  // Priority matrix
  importance     Level @default(MEDIUM)
  urgency        Level @default(MEDIUM)
  energyRequired Level @default(MEDIUM)
  priorityScore  Int?  // urgency + importance - energy penalty (0–6)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([projectId])
  @@index([priorityScore])
  @@index([urgency])
}

model DailyLog {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  feeling      String?
  accomplished String?
  distracted   String?
  improve      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Habit {
  id          String    @id @default(cuid())
  name        String
  description String?
  frequency   Frequency @default(DAILY)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]

  @@index([userId])
  @@index([isActive])
}

model HabitCompletion {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
  @@index([date])
}

model MemoryEntry {
  id         String           @id @default(cuid())
  title      String
  content    String
  type       MemoryType
  importance MemoryImportance @default(MEDIUM)
  source     MemorySource     @default(MANUAL)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([importance])
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum InboxCategory {
  IDEA
  TASK
  PROJECT
  GOAL
  JOURNAL
  LEARNING
  FINANCE
  HEALTH
  DANCE
  BUSINESS
  PERSONAL
}

enum InboxStatus {
  PENDING
  PROCESSED
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  BACKLOG
  PAUSED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Frequency {
  DAILY
  WEEKLY
}

enum Level {
  LOW
  MEDIUM
  HIGH
}

enum MemoryType {
  IDENTITY
  LIFE_PRINCIPLE
  PRODUCT_DECISION
  PRODUCT_CONTEXT
  LESSON_LEARNED
  CURRENT_STATE
  RELATIONSHIP_INSIGHT
  HEALTH_INSIGHT
  FINANCE_INSIGHT
  BUSINESS_IDEA
  PERSONAL_PATTERN
}

// Declaration order = sort order (LOW first → PERMANENT last for ASC)
enum MemoryImportance {
  LOW
  MEDIUM
  HIGH
  PERMANENT
}

enum MemorySource {
  CAPTURE
  MANUAL
  WEEKLY_REVIEW
  AI_REFLECTION
}
