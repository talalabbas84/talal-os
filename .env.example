DATABASE_URL="postgresql://talal_os:talal_os_password@localhost:5433/talal_os?schema=public"

AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="same-as-AUTH_SECRET-for-compatibility"
NEXTAUTH_URL="http://localhost:3000"

SEED_EMAIL="your@email.com"
SEED_PASSWORD="your-secure-password"
SEED_NAME="Your Name"

# AI provider for natural language capture
# Options: mock | gemini | openai | ollama
# Use "mock" to run fully offline with no API key required
AI_PROVIDER=mock

# Gemini (recommended) — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: override the default model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI (stub — not yet implemented)
# OPENAI_API_KEY=

# Ollama (stub — not yet implemented, for self-hosted models)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Push notifications — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:your@email.com
